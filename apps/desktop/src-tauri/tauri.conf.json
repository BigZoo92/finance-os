{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Finance-OS",
  "version": "0.1.0",
  "identifier": "com.financeos.desktop",
  "build": {
    "beforeDevCommand": "pnpm web:dev",
    "beforeBuildCommand": "pnpm web:build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "./static"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "freezePrototype": true
    },
    "windows": [
      {
        "label": "main",
        "title": "Finance-OS",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
