NODE_ENV=development
TZ=Europe/Paris
APP_VERSION=
APP_COMMIT_SHA=

POSTGRES_DB=finance_os
POSTGRES_USER=finance_os
POSTGRES_PASSWORD=finance_os_dev_password
POSTGRES_PORT=55432
DATABASE_URL=postgresql://finance_os:finance_os_dev_password@127.0.0.1:55432/finance_os

REDIS_PORT=6379

REDIS_URL=redis://localhost:6379

API_HOST=0.0.0.0
API_PORT=3001
# Optional internal token for server-to-server API operations.
# Accepted headers: Authorization: Bearer <token>, x-internal-token, x-finance-os-access-token.
# When set in production, configure the same value on both API and Web runtime envs.
PRIVATE_ACCESS_TOKEN=
# Optional debug token for /debug/routes endpoint in production.
DEBUG_METRICS_TOKEN=
POWENS_MANUAL_SYNC_COOLDOWN_SECONDS=300
AUTH_ADMIN_EMAIL=bigzoo@example.com
# Preferred admin hash vars (pbkdf2$... recommended; $argon2... legacy supported).
# Generate with: pnpm auth:hash-b64
AUTH_ADMIN_PASSWORD_HASH_B64=
AUTH_ADMIN_PASSWORD_HASH=
# Legacy fallback vars (used only if AUTH_ADMIN_PASSWORD_HASH* are empty).
AUTH_PASSWORD_HASH_B64=
AUTH_PASSWORD_HASH=pbkdf2$sha256$210000$replace-with-salt$replace-with-key
# 32+ bytes (raw utf-8, hex, base64, or base64url)
AUTH_SESSION_SECRET=replace-with-strong-session-secret
AUTH_SESSION_TTL_DAYS=30
AUTH_LOGIN_RATE_LIMIT_PER_MIN=5

WORKER_HEARTBEAT_MS=30000
WORKER_AUTO_SYNC_ENABLED=false
POWENS_SYNC_INTERVAL_MS=43200000
POWENS_SYNC_MIN_INTERVAL_PROD_MS=43200000
APP_URL=http://127.0.0.1:3000
WEB_URL=http://127.0.0.1:3000
API_URL=http://127.0.0.1:3001
API_INTERNAL_URL=http://127.0.0.1:3001
WEB_ORIGIN=http://127.0.0.1:3000
VITE_API_BASE_URL=/api
VITE_APP_ORIGIN=http://localhost:3000
VITE_APP_TITLE=finance-os

POWENS_CLIENT_ID=id
POWENS_CLIENT_SECRET=secret
POWENS_BASE_URL=https://your-api-domain.biapi.pro
POWENS_REDIRECT_URI_DEV=http://localhost:3000/powens/callback
POWENS_REDIRECT_URI_PROD=https://finance-os.enzogivernaud.fr/powens/callback
POWENS_DOMAIN=enzogivernaud-sandbox
POWENS_WEBVIEW_BASE_URL=https://webview.powens.com/connect
# Optional: provide full pre-built webview URL for sandbox/manual testing.
# POWENS_WEBVIEW_URL=https://webview.powens.com/connect?domain=enzogivernaud-sandbox.biapi.pro&client_id=id&redirect_uri=http%3A%2F%2Flocalhost%3A3000%2Fpowens%2Fcallback

# 32-byte key (raw, hex, or base64)
APP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
