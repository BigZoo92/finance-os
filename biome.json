{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/coverage",
      "!**/.turbo",
      "!**/.next",
      "!**/.output",
      "!**/routeTree.gen.ts",
      "!**/routeTree.gen.tsx",
      "!apps/web/src/components/reactbits/antigravity.tsx",
      "!apps/web/src/components/reactbits/chroma-grid.tsx",
      "!apps/web/src/components/reactbits/circular-text.tsx",
      "!apps/web/src/components/reactbits/dock.tsx",
      "!apps/web/src/components/reactbits/folder.tsx",
      "!apps/web/src/components/reactbits/glass-surface.tsx",
      "!apps/web/src/components/reactbits/liquid-ether.tsx",
      "!apps/web/src/components/reactbits/magic-bento.tsx",
      "!apps/web/src/components/reactbits/pixel-blast.tsx",
      "!apps/web/src/components/reactbits/pixel-trail.tsx",
      "!apps/web/src/components/reactbits/pixel-transition.tsx",
      "!apps/web/src/components/reactbits/shape-blur.tsx",
      "!apps/web/src/components/reactbits/staggered-menu.tsx"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "asNeeded",
      "trailingCommas": "es5",
      "arrowParentheses": "asNeeded"
    }
  }
}
