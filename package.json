{
  "name": "finance-os",
  "private": true,
  "version": "0.0.0",
  "description": "",
  "keywords": [],
  "author": "BigZoo",
  "license": "ISC",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev:apps": "concurrently -k -n api,worker,web \"pnpm api:dev\" \"pnpm worker:dev\" \"pnpm web:dev\"",
    "dev:all": "pnpm infra:up && pnpm dev:apps",
    "build": "pnpm -r --if-present build",
    "check:ci": "node scripts/check-ci.mjs --scope=auto",
    "check:ci:core": "node scripts/check-ci.mjs --scope=core",
    "check:ci:desktop": "node scripts/check-ci.mjs --scope=desktop",
    "check:ci:full": "node scripts/check-ci.mjs --scope=full",
    "docker:check": "node scripts/check-docker-workspace-manifest.mjs",
    "docker:build:smoke": "node scripts/docker-build-smoke.mjs",
    "affected:print": "node scripts/affected-tasks.mjs print",
    "affected:lint": "node scripts/affected-tasks.mjs lint",
    "affected:typecheck": "node scripts/affected-tasks.mjs typecheck",
    "affected:test": "node scripts/affected-tasks.mjs test",
    "affected:build": "node scripts/affected-tasks.mjs build",
    "python:lint": "node scripts/python-services.mjs lint",
    "python:format": "node scripts/python-services.mjs format",
    "python:format:check": "node scripts/python-services.mjs format-check",
    "python:test": "node scripts/python-services.mjs test",
    "python:check": "pnpm python:lint && pnpm python:format:check && pnpm python:test",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test": "node --test scripts/agentic/*.test.mjs scripts/desktop-scope.test.mjs scripts/agent-context/agent-context.test.mjs scripts/agent-context/sync-skills.test.mjs",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "api:dev": "pnpm --filter @finance-os/api dev",
    "api:start": "pnpm --filter @finance-os/api start",
    "api:typecheck": "pnpm --filter @finance-os/api typecheck",
    "infra:up": "docker compose --env-file .env -f infra/docker/docker-compose.dev.yml up -d",
    "infra:down": "docker compose --env-file .env -f infra/docker/docker-compose.dev.yml down",
    "infra:logs": "docker compose --env-file .env -f infra/docker/docker-compose.dev.yml logs -f",
    "infra:ps": "docker compose --env-file .env -f infra/docker/docker-compose.dev.yml ps",
    "db:generate": "pnpm --filter @finance-os/db db:generate",
    "db:migrate": "pnpm --filter @finance-os/db db:migrate",
    "db:studio": "pnpm --filter @finance-os/db db:studio",
    "auth:hash": "pnpm --filter @finance-os/api auth:hash",
    "auth:hash-b64": "pnpm --filter @finance-os/api auth:hash-b64",
    "worker:dev": "bun --watch apps/worker/src/index.ts",
    "worker:start": "pnpm --filter @finance-os/worker start",
    "worker:typecheck": "pnpm --filter @finance-os/worker typecheck",
    "web:dev": "pnpm --filter @finance-os/web dev",
    "web:build": "pnpm --filter @finance-os/web build",
    "web:start": "pnpm --filter @finance-os/web start",
    "web:typecheck": "pnpm --filter @finance-os/web typecheck",
    "web:test": "pnpm --filter @finance-os/web test",
    "gitnexus:analyze": "npx gitnexus analyze --skills",
    "gitnexus:analyze:full": "npx gitnexus analyze --embeddings --skills --verbose",
    "gitnexus:analyze:force": "npx gitnexus analyze --embeddings --skills --verbose --force",
    "gitnexus:status": "npx gitnexus status",
    "gitnexus:list": "npx gitnexus list",
    "gitnexus:mcp": "npx gitnexus mcp",
    "gitnexus:serve": "npx gitnexus serve",
    "gitnexus:wiki": "npx gitnexus wiki",
    "gitnexus:clean": "npx gitnexus clean",
    "gitnexus:sync-generated-skills": "node scripts/sync-gitnexus-generated-skills.mjs",
    "desktop:doctor": "node apps/desktop/scripts/doctor.mjs",
    "desktop:dev": "pnpm desktop:doctor && cd apps/desktop && cargo tauri dev",
    "desktop:build": "pnpm desktop:doctor && cd apps/desktop && cargo tauri build",
    "desktop:typecheck": "pnpm desktop:doctor && cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "desktop:ios:targets": "rustup target add aarch64-apple-ios aarch64-apple-ios-sim x86_64-apple-ios",
    "desktop:ios:init": "pnpm desktop:ios:targets && pnpm --filter @finance-os/desktop ios:init",
    "desktop:ios:dev": "pnpm --filter @finance-os/desktop ios:dev",
    "desktop:ios:build": "pnpm --filter @finance-os/desktop ios:build",
    "agent:context:audit": "node scripts/agent-context/audit.mjs",
    "agent:context:pack": "node scripts/agent-context/pack.mjs",
    "agent:context:estimate": "node scripts/agent-context/estimate.mjs",
    "agent:context:select": "node scripts/agent-context/select.mjs",
    "agent:context:check": "node scripts/agent-context/check.mjs",
    "agent:prompt:build": "node scripts/agent-context/prompt-builder.mjs",
    "agent:telemetry:record": "node scripts/agent-context/telemetry-record.mjs",
    "agent:skills:sync": "node scripts/agent-context/sync-skills.mjs sync",
    "agent:skills:check": "node scripts/agent-context/sync-skills.mjs check",
    "agent:skills:watch": "node scripts/agent-context/sync-skills.mjs watch"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.3.0",
    "concurrently": "^9.2.1",
    "gitnexus": "1.4.10",
    "typescript": "^5.9.3"
  }
}
