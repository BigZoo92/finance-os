+const sanitizeCsvCell = (value: string | number | null) => {
+  const text = value === null ? '' : String(value)
+  const escaped = text.replaceAll('"', '""')
+  return `"${escaped}"`
+}
+
+const buildTransactionsCsv = (transactions: DashboardTransactionsResponse['items']) => {
+  const header = [
+    'id',
+    'bookingDate',
+    'label',
+    'amount',
+    'currency',
+    'direction',
+    'category',
+    'subcategory',
+    'resolvedCategory',
+    'incomeType',
+    'tags',
+    'accountName',
+    'powensConnectionId',
+    'powensAccountId',
+  ]
+
+  const rows = transactions.map(transaction => {
+    return [
+      transaction.id,
+      transaction.bookingDate,
+      transaction.label,
+      transaction.amount.toFixed(2),
+      transaction.currency,
+      transaction.direction,
+      transaction.category,
+      transaction.subcategory,
+      transaction.resolvedCategory,
+      transaction.incomeType,
+      transaction.tags.join('|'),
+      transaction.accountName,
+      transaction.powensConnectionId,
+      transaction.powensAccountId,
+    ]
+      .map(value => sanitizeCsvCell(value))
+      .join(',')
+  })
+
+  return [header.join(','), ...rows].join('\n')
+}
+
+const downloadFile = ({
+  filename,
+  mimeType,
+  content,
+}: {
+  filename: string
+  mimeType: string
+  content: string
+}) => {
+  const blob = new Blob([content], { type: mimeType })
+  const url = URL.createObjectURL(blob)
+  const link = document.createElement('a')
+  link.href = url
+  link.download = filename
+  link.click()
+  URL.revokeObjectURL(url)
+}
+
