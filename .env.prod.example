# ---------------------------------------------------------------------------
# finance-os production environment
# ---------------------------------------------------------------------------
# PUBLIC URLS
# Put your production URL here:
APP_URL=https://finance-os.enzogivernaud.fr
WEB_URL=https://finance-os.enzogivernaud.fr
API_URL=https://finance-os.enzogivernaud.fr/api

# Immutable image deployment (GHCR)
# Never use a mutable tag like latest in production.
GHCR_IMAGE_NAME=ghcr.io/bigzoo92/finance-os
APP_IMAGE_TAG=v1.0.0

# Runtime
NODE_ENV=production
TZ=Europe/Paris
WEB_PORT=3000
APP_VERSION=
APP_COMMIT_SHA=
RUN_DB_MIGRATIONS=true
API_INTERNAL_URL=http://finance-os-api:3001
VITE_API_BASE_URL=/api
VITE_APP_ORIGIN=https://finance-os.enzogivernaud.fr
VITE_DASHBOARD_HEALTH_SIGNALS_ENABLED=true
VITE_DASHBOARD_HEALTH_GLOBAL_INDICATOR_ENABLED=true
VITE_DASHBOARD_HEALTH_WIDGET_BADGES_ENABLED=true
VITE_POWENS_SYNC_COOLDOWN_UI_ENABLED=true
VITE_POWENS_SYNC_COOLDOWN_UI_SECONDS=300
LOG_LEVEL=info
APP_DEBUG=0
# Set LOG_LEVEL=debug temporarily to inspect safe API auth-hash resolution logs.

# ---------------------------------------------------------------------------
# Database / Redis
# ---------------------------------------------------------------------------
POSTGRES_DB=finance_os
POSTGRES_USER=finance_os
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://finance_os:replace-with-a-strong-password@postgres:5432/finance_os

REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# API / Worker controls
# ---------------------------------------------------------------------------
# Optional internal token for server-to-server API operations.
# Accepted headers: Authorization: Bearer <token>, x-internal-token, x-finance-os-access-token.
# Use the same value for api and web runtime to allow SSR internal calls.
PRIVATE_ACCESS_TOKEN=
# Optional debug token for /debug/routes endpoint in production.
DEBUG_METRICS_TOKEN=
POWENS_MANUAL_SYNC_COOLDOWN_SECONDS=300
DEMO_DATASET_STRATEGY=v1
DEMO_PERSONA_MATCHING_ENABLED=1
SYNC_STATUS_PERSISTENCE_ENABLED=true
POWENS_DIAGNOSTICS_ENABLED=true
PWA_NOTIFICATIONS_ENABLED=true
PWA_CRITICAL_ENABLED=true
PUSH_DELIVERY_PROVIDER_URL=
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
DERIVED_RECOMPUTE_ENABLED=true
ENRICHMENT_BULK_TRIAGE_ENABLED=true
EXTERNAL_INTEGRATIONS_SAFE_MODE=false
AUTH_ADMIN_EMAIL=bigzoo@example.com
# Preferred admin hash variables (base64(utf8(hash)) to avoid Dokploy escaping issues).
# Hash format supports pbkdf2$... (recommended) and legacy $argon2...
# Generate with: pnpm auth:hash-b64
AUTH_ADMIN_PASSWORD_HASH_B64=replace-with-base64-password-hash
AUTH_ADMIN_PASSWORD_HASH=
# Legacy fallback (used only when AUTH_ADMIN_PASSWORD_HASH* are empty).
AUTH_PASSWORD_HASH_B64=
# Legacy fallback (used only when AUTH_ADMIN_PASSWORD_HASH* and AUTH_PASSWORD_HASH_B64 are empty).
AUTH_PASSWORD_HASH=
# 32+ bytes (raw utf-8, hex, base64, or base64url)
AUTH_SESSION_SECRET=replace-with-strong-session-secret
AUTH_SESSION_TTL_DAYS=30
AUTH_LOGIN_RATE_LIMIT_PER_MIN=5
# Local debug escape hatch only. Keep false/empty in real production.
AUTH_ALLOW_INSECURE_COOKIE_IN_PROD=

WORKER_HEARTBEAT_MS=30000
WORKER_HEALTHCHECK_MAX_AGE_MS=120000
WORKER_AUTO_SYNC_ENABLED=false
POWENS_SYNC_INTERVAL_MS=43200000
POWENS_SYNC_MIN_INTERVAL_PROD_MS=43200000
POWENS_SYNC_INCREMENTAL_LOOKBACK_DAYS=7
POWENS_FORCE_FULL_SYNC=false
# Comma-separated provider ids (e.g. "powens,bridge") to pause sync ingestion per provider.
POWENS_SYNC_DISABLED_PROVIDERS=

# ---------------------------------------------------------------------------
# Powens
# ---------------------------------------------------------------------------
POWENS_CLIENT_ID=replace-with-client-id
POWENS_CLIENT_SECRET=replace-with-client-secret
POWENS_BASE_URL=https://your-domain.biapi.pro
POWENS_DOMAIN=replace-with-powens-domain
POWENS_REDIRECT_URI_DEV=http://localhost:3000/powens/callback
POWENS_REDIRECT_URI_PROD=https://finance-os.enzogivernaud.fr/powens/callback
POWENS_WEBVIEW_BASE_URL=https://webview.powens.com/connect
POWENS_WEBVIEW_URL=

# 32-byte key (raw utf-8, 64-char hex, or base64)
APP_ENCRYPTION_KEY=replace-with-32-byte-key

LIVE_NEWS_INGESTION_ENABLED=true
NEWS_AI_CONTEXT_BUNDLE_ENABLED=true
NEWS_MAX_PROVIDER_ITEMS_PER_RUN=20
NEWS_METADATA_FETCH_ENABLED=true
NEWS_METADATA_FETCH_TIMEOUT_MS=2500
NEWS_METADATA_FETCH_MAX_BYTES=131072
NEWS_SCRAPER_USER_AGENT=finance-os-news/1.0 (+https://finance-os.enzogivernaud.fr)
SEC_USER_AGENT=finance-os-news/1.0 (+https://finance-os.enzogivernaud.fr)
NEWS_PROVIDER_HN_ENABLED=true
NEWS_PROVIDER_HN_QUERY=finance OR markets OR inflation OR AI
NEWS_PROVIDER_GDELT_ENABLED=true
NEWS_PROVIDER_GDELT_QUERY=(finance OR inflation OR rates OR sanctions OR cybersecurity OR "artificial intelligence")
NEWS_PROVIDER_ECB_RSS_ENABLED=true
NEWS_PROVIDER_ECB_RSS_FEED_URLS=https://www.ecb.europa.eu/rss/press.html,https://www.ecb.europa.eu/rss/statpress.html,https://www.ecb.europa.eu/rss/pub.html,https://www.ecb.europa.eu/rss/blog.html
NEWS_PROVIDER_ECB_DATA_ENABLED=false
NEWS_PROVIDER_ECB_DATA_SERIES_KEYS=EXR/D.USD.EUR.SP00.A
NEWS_PROVIDER_FED_ENABLED=true
NEWS_PROVIDER_FED_FEED_URLS=https://www.federalreserve.gov/feeds/press_monetary.xml,https://www.federalreserve.gov/feeds/press_all.xml,https://www.federalreserve.gov/feeds/speeches_and_testimony.xml
NEWS_PROVIDER_SEC_ENABLED=true
NEWS_PROVIDER_SEC_TICKERS=AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA
NEWS_PROVIDER_FRED_ENABLED=false
NEWS_PROVIDER_FRED_SERIES_IDS=FEDFUNDS,CPIAUCSL,UNRATE,DGS10
FRED_API_KEY=
NEWS_AUTO_INGEST_ENABLED=true
NEWS_FETCH_INTERVAL_MS=14400000
FAILSOFT_POLICY_ENABLED=true
FAILSOFT_SOURCE_ORDER=live,cache,demo
FAILSOFT_ALERTS_ENABLED=true
FAILSOFT_NEWS_ENABLED=true
FAILSOFT_INSIGHTS_ENABLED=true
